{
  "name": "lumen",
  "version": "0.0.1",
  "description": "Beautiful, consistent Angular icon components — crafted for accessibility and tree-shaking.",
  "author": {
    "name": "Andrii",
    "url": "https://github.com/andersseen"
  },
  "keywords": [
    "angular",
    "icons",
    "svg",
    "ui",
    "components",
    "lumen"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/andersseen/lumen-icons.git"
  },
  "homepage": "https://lumen-icons.dev",
  "bugs": {
    "url": "https://github.com/andersseen/lumen-icons/issues"
  },
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=20.19.1"
  },
  "scripts": {
    "ng": "ng",
    "dev": "vite",
    "start": "pnpm run dev",
    "build": "pnpm run build:all",
    "build:all": "pnpm run build:lib && pnpm run build:app",
    "build:app": "vite build",
    "build:lib": "tsup --config packages/icons/tsup.config.ts",
    "watch": "vite build --watch",
    "lint": "eslint .",
    "typecheck": "pnpm run typecheck:app && pnpm run typecheck:lib",
    "typecheck:app": "tsc --noEmit -p tsconfig.app.json",
    "typecheck:lib": "tsc --noEmit -p packages/icons/tsconfig.lib.json",
    "test": "pnpm run test:unit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "playwright:install": "playwright install",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test:unit",
    "preview": "vite preview"
  },
  "dependencies": {
    "@analogjs/content": "^2.4.10",
    "@analogjs/router": "^2.4.10",
    "@angular/animations": "^21.0.0",
    "@angular/common": "^21.0.0",
    "@angular/compiler": "^21.0.0",
    "@angular/core": "^21.0.0",
    "@angular/forms": "^21.0.0",
    "@angular/platform-browser": "^21.0.0",
    "@angular/platform-server": "^21.0.0",
    "@angular/router": "^21.0.0",
    "@tailwindcss/vite": "^4.1.4",
    "@voltui/components": "^0.1.0",
    "front-matter": "^4.0.2",
    "h3": "^1.13.0",
    "marked": "^15.0.7",
    "marked-gfm-heading-id": "^4.1.1",
    "marked-highlight": "^2.2.1",
    "marked-mangle": "^1.1.10",
    "postcss": "^8.5.3",
    "prismjs": "^1.29.0",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.4",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@analogjs/platform": "^2.4.10",
    "@analogjs/vite-plugin-angular": "^2.4.10",
    "@analogjs/vitest-angular": "^2.4.10",
    "@angular/build": "^21.0.0",
    "@angular/cli": "^21.0.0",
    "@angular/compiler-cli": "^21.0.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/angular": "^19.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "angular-eslint": "^21.3.1",
    "eslint": "^10.2.1",
    "jsdom": "^22.0.0",
    "publint": "^0.3.18",
    "tsup": "^8.5.1",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.0",
    "vite-tsconfig-paths": "^4.2.0",
    "vitest": "^4.1.0",
    "zone.js": "^0.16.1"
  },
  "overrides": {
    "vite": "$vite",
    "vitest": "$vitest"
  }
}
